# Copy to .env and adjust. Used by docker compose and local tooling.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=poker_trainer

# API on host (bun run dev:api) — use localhost because Postgres publishes 5432.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/poker_trainer

# API inside docker compose uses hostname `db` (set in compose file for the api service).

# OpenAPI codegen (bun run codegen) — API must be running.
OPENAPI_URL=http://127.0.0.1:8000/openapi.json

# Web app — Vite
VITE_API_URL=http://127.0.0.1:8000
