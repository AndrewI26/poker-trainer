# DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=poker_trainer
POSTGRES_PORT=5432

# API
API_PORT=8000
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Web app
VITE_API_URL=http://127.0.0.1:${API_PORT}

# Mobile app — use machine IP for physical device, 10.0.2.2 for Android emulator
EXPO_PUBLIC_API_URL=http://127.0.0.1:${API_PORT}

# OpenAPI codegen (bun run codegen) — API must be running
OPENAPI_URL=http://127.0.0.1:${API_PORT}/openapi.json
